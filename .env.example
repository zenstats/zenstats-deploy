# ZenStats 部署环境变量配置
# 复制此文件为 .env 并修改对应的值
#   cp .env.example .env

# ===== 必填 =====

# MaxMind GeoIP License Key（免费注册获取：https://dev.maxmind.com/geoip/geolite2-free-geolocation-data）
# 不填写将使用 Loyalsoldier/geoip 免费数据库作为降级方案
ZENSTATS_MAXMIND_LICENSE_KEY=your_license_key_here

# ===== 安全（强烈建议修改） =====

# JWT 签名密钥 — 务必替换为随机字符串！
# 生成方式：openssl rand -base64 32
ZENSTATS_SECRET_KEY=change_me_to_a_random_secret

# ===== 域名配置 =====

# 部署域名（用于生成前端追追踪脚本中的 data-domain）
ZENSTATS_DOMAIN=stats.example.com

# ===== 数据库密码（生产务必修改） =====

DB_PASSWORD=postgres

# ===== 可选 =====

# PostgreSQL 连接（默认值通常无需修改）
# ZENSTATS_DB_HOST=zenstats_db
# ZENSTATS_DB_PORT=5432
# ZENSTATS_DB_USERNAME=postgres
# ZENSTATS_DB_DATABASE=zenstats

# ClickHouse 连接
# ZENSTATS_CLICKHOUSE_ADDR=zenstats_events_db:9000
# ZENSTATS_CLICKHOUSE_USERNAME=default
# ZENSTATS_CLICKHOUSE_PASSWORD=

# 应用配置
# ZENSTATS_LOG_LEVEL=info          # debug | info | warn | error
# ZENSTATS_POOL_SIZE=100           # 事件处理协程池大小
# ZENSTATS_SCHEME_HTTP_PORT=8080   # HTTP 监听端口
